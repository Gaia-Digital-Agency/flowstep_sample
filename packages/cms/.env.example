# Copy to .env locally; on gda-s01 lives in /var/www/flowstep/shared/.env

PAYLOAD_SECRET=replace-with-32+-random-bytes
DATABASE_URI=postgres://flowstep:flowstep_local_password@127.0.0.1:5432/flowstep
PUBLIC_SERVER_URL=http://localhost:5173

PORT=3030
NODE_ENV=development

# SMTP for contact form notifications (optional in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Gaia AI <noreply@gaiada.online>"
CONTACT_NOTIFY_TO=hello@gaiada.online

# Initial admin user (used by `pnpm seed`)
INITIAL_ADMIN_EMAIL=super_admin@email.com
INITIAL_ADMIN_PASSWORD=Teameditor@123
